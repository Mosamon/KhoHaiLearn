generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model UserStats {
  id             Int      @id @default(autoincrement())
  email          String   @unique
  statsJson      String   @default("{}")
  updatedAt      DateTime @updatedAt
}
